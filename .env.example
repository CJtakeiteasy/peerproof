# Required for live GPT-5.6 paper analysis.
OPENAI_API_KEY=

# Keep the competition-required model explicit.
OPENAI_MODEL=gpt-5.6

# Optional separate credential/model for the Codex investigator.
CODEX_API_KEY=
CODEX_MODEL=gpt-5.6

# Enable the Codex SDK as PeerProof's repository investigator.
# Leave false for the credential-free judge demo.
PEERPROOF_USE_CODEX=false

# Recording guardrails. When true, any live model failure aborts the audit;
# reviewed fixture fallback is forbidden.
PEERPROOF_REQUIRE_LIVE_GPT=false
PEERPROOF_REQUIRE_LIVE_CODEX=false

# Optional live agent-evaluation settings. Reports default to the ignored
# .peerproof/evals directory and contain redacted per-run receipts and metrics.
PEERPROOF_AGENT_EVAL_RUNS=3
PEERPROOF_AGENT_EVAL_OUTPUT=

# The curated demo runs trusted fixture code locally. Never enable local
# execution for arbitrary uploaded repositories.
PEERPROOF_ALLOW_TRUSTED_DEMO_EXECUTION=true

# Optional protection for the public paper-extraction endpoint.
PEERPROOF_JUDGE_TOKEN=
PEERPROOF_EXTRACT_PER_MINUTE=3
PEERPROOF_EXTRACT_PER_DAY=20

# Public benchmark buttons use reviewed offline fixtures by default, even when
# API credentials are present. Live browser audits require this flag AND a
# valid PEERPROOF_JUDGE_TOKEN. The global budget counts expected AI calls across
# authorized demo audits and direct paper extraction.
PEERPROOF_PUBLIC_LIVE_AUDITS=false
PEERPROOF_GLOBAL_AI_DAILY_LIMIT=50

# All audit endpoints share rate and concurrency controls.
PEERPROOF_AUDIT_PER_MINUTE=8
PEERPROOF_AUDIT_PER_DAY=100
PEERPROOF_MAX_CONCURRENT_AUDITS=2

# Enable only behind a trusted reverse proxy that overwrites, rather than
# appends untrusted, X-Forwarded-For headers. Otherwise clients can spoof the
# address used by rate limits.
PEERPROOF_TRUST_PROXY=false

# Audit ledgers are intentionally bounded in memory and on disk.
PEERPROOF_MAX_MEMORY_AUDITS=20
PEERPROOF_AUDIT_TTL_MS=3600000

# Optional deployed source commit. Must be exactly 40 hexadecimal characters;
# invalid configured values stop startup. This records an identifier and source,
# not cryptographic verification of the release.
PEERPROOF_COMMIT=

PORT=4173
HOST=127.0.0.1
